\subsection{Stage 3: SHAP Feature Attribution}

SHAP~\cite{lundberg2017} decomposes any prediction $f(\mathbf{x})$ into
a sum of per-feature contributions:

\begin{equation}
  f(\mathbf{x}) = \phi_0 + \sum_{j=1}^{M} \phi_j
  \label{eq:shap}
\end{equation}

where $\phi_0 = \mathbb{E}[f(\mathbf{x})]$ is the global baseline and
each Shapley value $\phi_j$ is:

\begin{equation}
  \phi_j
    = \!\!\sum_{S \subseteq F\setminus\{j\}}\!\!
      \frac{|S|!\,(|F|-|S|-1)!}{|F|!}
      \bigl[f_{S\cup\{j\}}(\mathbf{x}_{S\cup\{j\}})
           - f_S(\mathbf{x}_S)\bigr]
  \label{eq:shapval}
\end{equation}

This is the Shapley value from cooperative game theory.
It guarantees that contributions sum to the full prediction gap from
baseline (efficiency), that identical features receive identical attribution
(symmetry), and that features with no effect receive zero (dummy property).

TreeExplainer computes exact Shapley values for XGBoost in polynomial time
$O(TLD^2)$ in the number of trees $T$, depth $D$, and leaves $L$.
This makes it fast enough to run after every single prediction, not just
in batch analysis.

PhishXplain generates two outputs from SHAP:
a beeswarm summary plot showing global feature impact across the full test
set, and a waterfall plot for any individual prediction showing which
features pushed the output above or below the decision threshold.

\subsection{Evaluation Metrics}

The same metrics as the base paper are reported to allow direct comparison,
with Recall and APS treated as primary because a missed phishing URL
exposes a user to credential theft while a false positive is recoverable.

\begin{align}
  \text{Acc}  &= \frac{TP+TN}{TP+TN+FP+FN}         \label{eq:acc}\\
  \text{Prec} &= \frac{TP}{TP+FP}                   \label{eq:prec}\\
  \text{Rec}  &= \frac{TP}{TP+FN}                   \label{eq:rec}\\
  F_1         &= 2\cdot\frac{\text{Prec}\times\text{Rec}}
                             {\text{Prec}+\text{Rec}} \label{eq:f1}\\
  \text{AUC}  &= \int_0^1 \text{TPR}(u)\,du          \label{eq:auc}\\
  \text{APS}  &= 1 - \frac{0.5 \cdot FP + 0.5 \cdot FN}{N}
  \label{eq:aps}
\end{align}

\subsection{Full Pipeline Algorithm}

\begin{algorithm}[H]
\caption{PhishXplain}
\label{alg:main}
\begin{algorithmic}[1]
\Require Dataset $D = \{(\mathbf{x}_i, y_i)\}_{i=1}^{N}$
\Ensure Model $\mathcal{M}$, metrics $\mathcal{E}$, SHAP values $\Phi$

\State Impute missing values (median); label-encode categoricals
\State $D_{\text{tr}}, D_{\text{te}} \leftarrow
       \textsc{StratifiedSplit}(D,\;0.8,\;\text{seed}{=}42)$

\State \textbf{// Gap 1: balance training partition only}
\State $D_{\text{bal}} \leftarrow
       \textsc{SMOTE}(D_{\text{tr}},\;k{=}5,\;\text{seed}{=}42)$
       \Comment{Eq.~\ref{eq:smote}}

\State $\mathcal{F}_{14} \leftarrow
       \textsc{PermutationImportance}(D_{\text{bal}},\;14)$
\State $\mathbf{X}^{\text{tr}} \leftarrow D_{\text{bal}}[\mathcal{F}_{14}];\quad
       \mathbf{X}^{\text{te}} \leftarrow D_{\text{te}}[\mathcal{F}_{14}]$

\State \textbf{// Gap 3: ensemble classifier with F$_1$-tuned hyperparameters}
\State $\theta^* \leftarrow
       \textsc{GridSearchCV}(\text{XGB},\;\text{Table~\ref{tab:hparams}},\;
       5\text{-fold},\;F_1)$
\State $\mathcal{M} \leftarrow
       \textsc{XGB.fit}(\mathbf{X}^{\text{tr}},\;y_{\text{bal}};\;\theta^*)$
       \Comment{Eqs.~\ref{eq:xgb}--\ref{eq:shapval}}

\State $\hat{\mathbf{y}} \leftarrow
       \mathcal{M}.\textsc{predict}(\mathbf{X}^{\text{te}})$
\State $\mathcal{E} \leftarrow
       \textsc{Metrics}(\hat{\mathbf{y}},\;y_{\text{te}})$
       \Comment{Eqs.~\ref{eq:acc}--\ref{eq:aps}}

\State \textbf{// Gap 2: per-prediction explanations}
\State $\Phi \leftarrow
       \textsc{shap.TreeExplainer}(\mathcal{M})
       .\textsc{shap\_values}(\mathbf{X}^{\text{te}})$
       \Comment{Eq.~\ref{eq:shapval}}
\State Output: beeswarm summary plot, waterfall plot per instance

\State \textbf{// Gap 4: secondary dataset}
\State Repeat Steps 1--13 on UCI Dataset~\cite{uci_phishing}
       (11,055 URLs, 30 features)

\State \Return $\mathcal{M},\;\mathcal{E},\;\Phi$
\end{algorithmic}
\end{algorithm}

